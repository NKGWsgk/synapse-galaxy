# コピーして .env.local にリネームし、= の右に値を入れてください
# 3 つとも同じ Supabase プロジェクトの Dashboard → Settings → API から。
# NEXT_PUBLIC_* … Publishable（sb_publishable_…）または Legacy「anon」
# SUPABASE_SERVICE_ROLE_KEY … Secret（sb_secret_…）または Legacy「service_role」

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
GEMINI_API_KEY=

# 任意
# GEMINI_TEXT_MODEL=
# AMAZON_AFFILIATE_TAG=
