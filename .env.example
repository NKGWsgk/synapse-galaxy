# コピーして .env.local にリネームし、= の右に値を入れてください
# 3 つとも同じ Supabase プロジェクトの Dashboard → Settings → API から。
# NEXT_PUBLIC_* … Publishable（sb_publishable_…）または Legacy「anon」
# SUPABASE_SERVICE_ROLE_KEY … Secret（sb_secret_…）または Legacy「service_role」

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
GEMINI_API_KEY=

# 本番 URL（SEO: metadataBase / sitemap / OGP 用。Vercel では VERCEL_URL でも可）
# NEXT_PUBLIC_SITE_URL=https://synapse-galaxy.vercel.app

# 任意
# Gemini でエッジ用キーワードの改行だけ提案する（入力保存時、`GEMINI_API_KEY` 必須）
# GEMINI_EDGE_KEYWORD_BREAK=1
# GEMINI_TEXT_MODEL=
# AMAZON_AFFILIATE_TAG=
# U-NEXT 提携（ASP の cid / utm_source を .env.local に設定）
# NEXT_PUBLIC_UNEXT_AFFILIATE_CID=
# UNEXT_AFFILIATE_CID=
# NEXT_PUBLIC_UNEXT_AFFILIATE_UTM_SOURCE=
# UNEXT_AFFILIATE_UTM_SOURCE=
